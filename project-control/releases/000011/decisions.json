{
  "decisions": [
    {
      "id": "MVPOS-ADR-001",
      "status": "active",
      "statement": "The MVP OS source repository self-hosts Project Control as its only startup authority.",
      "source_events": [
        "release:000002:ADR-001"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-002",
      "status": "active",
      "statement": "The source repository never self-syncs; downstream pull-request sync remains a separate distribution mechanism.",
      "source_events": [
        "release:000002:ADR-002"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-004",
      "status": "active",
      "statement": "Secret values are forbidden in every Project Control field, including command arguments, source-event references, and manifests.",
      "source_events": [
        "release:000002:ADR-004"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-005",
      "status": "active",
      "statement": "Custom implementation requires a validated Outcome-First and Reuse-First contract; final conditional evidence is machine-validated before READY.",
      "source_events": [
        "context:mvp-os-improvement-handoff:2026-07-21",
        "context:mvp-os-v2.1-implement:2026-07-21"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-006",
      "status": "active",
      "statement": "Hermes is an optional non-authoritative runtime for connectors, schedules, local tasks, files, tools, and gateway lifecycle; it is not a mandatory LLM proxy.",
      "source_events": [
        "context:mvp-os-improvement-handoff:2026-07-21"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-007",
      "status": "active",
      "statement": "New Project Control releases catalog decision source events with sanitized durable references, timestamps, and content hashes while startup remains history-free.",
      "source_events": [
        "context:mvp-os-improvement-handoff:2026-07-21"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-009",
      "status": "active",
      "statement": "Task contracts use proportional short and full Outcome-First and Reuse-First modes; short mode is limited to bounded local work without conditional scope.",
      "source_events": [
        "decision:proportional-gate:2026-07-22"
      ],
      "supersedes": []
    },
    {
      "id": "MVPOS-ADR-010",
      "status": "active",
      "statement": "MVP OS v2.1.1 becomes official only after merge to main, matching tag creation, successful verification, independent review, and push of both main and tag.",
      "source_events": [
        "contract:mvp-os-v2.1.1:2026-07-22"
      ],
      "supersedes": [
        "MVPOS-ADR-008"
      ]
    },
    {
      "id": "MVPOS-ADR-012",
      "status": "active",
      "statement": "Schema v1 task contracts pass only when their exact file SHA-256 is registered in current hash-verified Project Control acceptance.",
      "source_events": [
        "decision:legacy-contract-hash-binding:2026-07-23"
      ],
      "supersedes": [
        "MVPOS-ADR-011"
      ]
    }
  ],
